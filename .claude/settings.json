{
    "$schema":  "https://json.schemastore.org/claude-code-settings.json",
    "permissions":  {
                        "allow":  [
                                      "Bash(dotnet *)",
                                      "Bash(npm *)",
                                      "Bash(git status*)",
                                      "Bash(git diff*)",
                                      "Bash(git log*)",
                                      "Bash(git show*)",
                                      "Bash(git branch)",
                                      "Bash(git branch --list*)",
                                      "Bash(git ls-files*)",
                                      "Bash(git rev-parse*)",
                                      "Bash(git fetch*)",
                                      "Bash(git stash list*)",
                                      "Bash(sqllocaldb *)",
                                      "mcp__playwright__browser_take_screenshot",
                                      "PowerShell(dotnet *)",
                                      "PowerShell(npm *)",
                                      "PowerShell(sqlcmd *)",
                                      "mcp__playwright__browser_navigate",
                                      "mcp__atlassian__getAccessibleAtlassianResources"
                                  ],
                        "ask":  [
                                    "Bash(git push --force*)",
                                    "Bash(git push -f*)",
                                    "Bash(git reset --hard*)",
                                    "Bash(git branch -d*)",
                                    "Bash(git branch -D*)",
                                    "Bash(git checkout -- *)",
                                    "Bash(git restore*)",
                                    "Bash(git clean*)",
                                    "Bash(git stash drop*)",
                                    "Bash(git stash clear*)",
                                    "Bash(rm -rf*)",
                                    "Bash(rm -fr*)",
                                    "Bash(rm -r *)",
                                    "Bash(kill*)",
                                    "Bash(taskkill*)",
                                    "Bash(dotnet ef migrations remove*)",
                                    "Bash(dotnet ef database drop*)",
                                    "Bash(dotnet nuget delete*)",
                                    "Bash(npm publish*)",
                                    "PowerShell(git push --force*)",
                                    "PowerShell(git push -f*)",
                                    "PowerShell(git reset --hard*)",
                                    "PowerShell(git branch -d*)",
                                    "PowerShell(git branch -D*)",
                                    "PowerShell(git clean*)",
                                    "PowerShell(git stash drop*)",
                                    "PowerShell(git stash clear*)",
                                    "PowerShell(Remove-Item *-Recurse*)",
                                    "PowerShell(Remove-Item *-Force*)",
                                    "PowerShell(Stop-Process*)",
                                    "PowerShell(taskkill*)",
                                    "PowerShell(dotnet ef migrations remove*)",
                                    "PowerShell(dotnet ef database drop*)",
                                    "PowerShell(dotnet nuget delete*)",
                                    "PowerShell(npm publish*)"
                                ]
                    },
    "hooks":  {
                  "PreToolUse":  [
                                     {
                                         "matcher":  "Edit|Write",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/scripts/guard-sensitive-files.ps1"
                                                       },
                                                       {
                                                           "type":  "command",
                                                           "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/scripts/guard-idesign.ps1"
                                                       }
                                                   ]
                                     }
                                 ],
                  "Stop":  [
                               {
                                   "hooks":  [
                                                 {
                                                     "type":  "command",
                                                     "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/scripts/session-summary.ps1"
                                                 },
                                                 {
                                                     "type":  "command",
                                                     "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/scripts/notify.ps1"
                                                 }
                                             ]
                               }
                           ],
                  "PostToolUse":  [
                                      {
                                          "matcher":  "Edit|Write",
                                          "hooks":  [
                                                        {
                                                            "type":  "command",
                                                            "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/scripts/migration-reminder.ps1"
                                                        },
                                                        {
                                                            "type":  "command",
                                                            "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/scripts/format-cs.ps1"
                                                        }
                                                    ]
                                      }
                                  ]
              },
    "enabledMcpjsonServers":  [
                                  "atlassian",
                                  "playwright",
                                  "git",
                                  "mssql"
                              ]
}
